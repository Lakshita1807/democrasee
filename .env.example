# DemocraSee - Cloud Run Environment Variables Template

# Port for the server (Cloud Run uses 8080 by default)
PORT=8080

# Gemini API Key for AI Assistant and Translation
# Get one from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# News API Key (Optional if using proxy)
# NEWS_API_KEY=your_news_api_key_here

# Debug flag for logging
DEBUG=false
